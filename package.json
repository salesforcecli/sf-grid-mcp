{
  "name": "@salesforce/sf-grid-mcp",
  "version": "0.1.0",
  "description": "MCP server for Agentforce Grid — exposes the Grid Connect API to LLM agents (Claude Code, Cursor, ChatGPT desktop) via the Model Context Protocol",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agentforce",
    "agentforce-grid",
    "salesforce",
    "grid",
    "claude",
    "cursor",
    "llm-agents",
    "sf-cli"
  ],
  "license": "Apache-2.0",
  "author": "Salesforce",
  "homepage": "https://github.com/salesforcecli/sf-grid-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salesforcecli/sf-grid-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/salesforcecli/sf-grid-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "bin": {
    "sf-grid-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "evals": "vitest run --config vitest.evals.config.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
